generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  profileImage String?
  firstName    String?
  lastName     String?
  email        String     @unique
  phoneNumber  String?
  password     String?
  fcmToken     String?
  role         UserRole   @default(USER)
  status       UserStatus @default(INACTIVE)

  isVerified       Boolean   @default(false)
  otp              Int?
  expirationOtp    DateTime?
  gender           String?
  dob              DateTime?
  lat              Float?
  lng              Float?
  isNotificationOn Boolean   @default(true)

  provider   String? // google, facebook etc
  providerId String? // social provider id
  memories   Memory[]
  event      Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  EventLike  EventLike[]
  MemoryLike MemoryLike[]

  @@map("users")
}

model Memory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  description String
  address     String?
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId     String       @db.ObjectId
  user       User         @relation(fields: [userId], references: [id])
  MemoryLike MemoryLike[]
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  description String
  address     String?
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  EventLike EventLike[]
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model EventLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.ObjectId

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemoryLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.ObjectId

  memory   Memory @relation(fields: [memoryId], references: [id])
  memoryId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

