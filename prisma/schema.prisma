generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  profileImage String?
  firstName    String?
  lastName     String?
  email        String     @unique
  about        String?    @default("")
  phoneNumber  String?
  password     String?
  fcmToken     String?
  role         UserRole   @default(USER)
  status       UserStatus @default(INACTIVE)
  age          Int?
  address      String?    @default("")

  // 🔑 Referral fields
  referralCode String  @unique
  referredBy   String? @db.ObjectId
  referrer     User?   @relation("UserReferrals", fields: [referredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals    User[]  @relation("UserReferrals")
  isDatingMode Boolean @default(false)

  isVerified       Boolean   @default(false)
  isFaceVerified   Boolean   @default(false)
  otp              Int?
  expirationOtp    DateTime?
  gender           String?   @default("")
  // dating 
  totalCoins       Float     @default(0)
  interestedGender String    @default("")
  interests        String[]  @default([])
  datingInterests  String[]  @default([])
  datingAbout      String?   @default("")
  datingImage      String[]  @default([])
  //subscription
  aiMessage        Int       @default(0)
  boots            Int       @default(0)
  priorityLikes    Int       @default(0)

  dob              DateTime?
  lat              Float?    @default(0.0)
  lng              Float?    @default(0.0)
  isNotificationOn Boolean   @default(true)

  provider   String? // google, facebook etc
  providerId String? // social provider id
  memories   Memory[]
  event      Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  EventLike     EventLike[]
  MemoryLike    MemoryLike[]
  Comment       Comment[]
  followers     Follow[]     @relation("Followers") // amy jare follw kortase,
  following     Follow[]     @relation("Following") // ami jare follw kortasi
  SentChats     Chat[]       @relation("SentChats")
  ReceivedChats Chat[]       @relation("ReceivedChats")

  SenderRooms   Room[] @relation("SenderRooms")
  ReceiverRooms Room[] @relation("ReceiverRooms")

  reportsMade    Report[] @relation("ReportCreatedBy")
  reportsOnMe    Report[] @relation("ReportedUser")
  blockedUsers   Block[]  @relation("BlockerRelation")
  blockedByUsers Block[]  @relation("BlockedRelation")

  purchases          GiftPurchase[]
  sentGifts          GiftSend[]     @relation("GiftSender")
  receivedGifts      GiftSend[]     @relation("GiftReceiver")
  sentGiftsPopUp     gitPopUp[]     @relation("SentGifts")
  receivedGiftsPopUp gitPopUp[]     @relation("ReceivedGifts")
  sendCoin           CoinGiftSend[] @relation("CoinGiftSender")
  receivedCoin       CoinGiftSend[] @relation("CoinGiftReceiver")
  payments           Payment[]

  //  Notifications where this user is the recipient
  notificationsReceived Notification[] @relation("Notification_receiverId")

  //  Notifications where this user is the sender
  notificationsSent Notification[] @relation("NotificationSender")
  ReportPost        ReportPost[]
  managerRole       String[]       @default([])
  // Likes that this user has given to other users
  likesGiven        UserLike[]     @relation("UserLikesGiven")
  // Likes that this user has received from other users
  likesReceived     UserLike[]     @relation("UserLikesReceived")
  Subscription      Subscription[]

  @@map("users")
}

model Interest {
  id       String           @id @default(auto()) @map("_id") @db.ObjectId
  name     String           @unique
  image    String?          @default("")
  category InterestCategory @unique
}

enum InterestCategory {
  TRAVEL
  MOVIES
  MUSIC
  FOOTBALL
  PETS_LOVE
  GARDENING
  WRITING
  COOKING
  NATURE
  FASHION
  DEBATE
  SCIENCE
  MEDITATION
  GAMING
}

model Memory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  description String
  address     String?
  lat         Float    @default(0.0)
  lng         Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId     String       @db.ObjectId
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  MemoryLike MemoryLike[]
  Comment    Comment[]
  ReportPost ReportPost[]
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  description String
  address     String?
  lat         Float    @default(0.0)
  lng         Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  EventLike EventLike[]
}

model gitPopUp {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  giftImage  String @default("")
  senderId   String @db.ObjectId
  receiverId String @db.ObjectId
  type       PopUp  @default(GIFT)
  isSeen       Boolean  @default(false)

  // 🧩 Relations
  sender   User @relation("SentGifts", fields: [senderId], references: [id])
  receiver User @relation("ReceivedGifts", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
}

enum PopUp {
  GIFT
  COIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  MANAGER
}

model EventLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventId String @db.ObjectId
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemoryLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  memoryId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  content String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  memoryId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  follower      User          @relation("Following", fields: [followerId], references: [id], onDelete: Cascade) // ami jare follw kortasi
  followerId    String        @db.ObjectId
  requestStatus RequestStatus @default(PENDING)
  modeType      ModeType      @default(SOCIAL)
  following     User          @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade) // amy jare follw kortase,
  followingId   String        @db.ObjectId

  createdAt DateTime @default(now())
}

model Chat {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    String
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  roomId     String   @db.ObjectId
  images     String[] @default([])

  isRead Boolean @default(false)

  sender   User @relation("SentChats", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedChats", fields: [receiverId], references: [id], onDelete: Cascade)
  room     Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String @db.ObjectId
  receiverId String @db.ObjectId
  sender     User   @relation("SenderRooms", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User   @relation("ReceiverRooms", fields: [receiverId], references: [id], onDelete: Cascade)
  chats      Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Reporter 
  reporterId String @db.ObjectId
  reporter   User   @relation("ReportCreatedBy", fields: [reporterId], references: [id], onDelete: Cascade)

  // Reported user
  reportedUserId String @db.ObjectId
  reportedUser   User   @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
}

model ReportPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Reporter 
  reporterId String @db.ObjectId
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  // Reported user
  memoryId String @db.ObjectId
  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model Block {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  blockerId     String   @db.ObjectId
  blockedUserId String   @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  blocker     User @relation("BlockerRelation", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User @relation("BlockedRelation", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId]) // Prevent duplicate blocks
}

model Notification {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  type         NotificationType
  title        String
  message      String?
  isRead       Boolean          @default(false)
  followStatus RequestStatus    @default(REJECTED)
  image        String?          @default("")

  receiverId String  @db.ObjectId
  receiver   User    @relation("Notification_receiverId", fields: [receiverId], references: [id], onDelete: Cascade)
  senderId   String? @db.ObjectId
  sender     User?   @relation("NotificationSender", fields: [senderId], references: [id])

  targetType String? @default("") // e.g., "event", "memory", "comment", etc.
  targetId   String? @default("") // ID of the item the notification is about

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  PURCHASE
  GIFT
  MENTION
  MESSAGE
  EVENT_INVITE
  MEMORY_SHARE
  REPORT
  BLOCK
}

// Dating and Social modes

model Coins {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  coinAmount String
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CoinGiftSend {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  totalCoin  Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  sender   User @relation("CoinGiftSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("CoinGiftReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model GiftCard {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String?        @default("")
  gender       Gender         @default(HIM)
  category     GiftCategory
  image        String
  price        Float
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  GiftPurchase GiftPurchase[]
  GiftSend     GiftSend[]
}

enum Gender {
  HIM
  HER
  EVERYONE
}

model GiftPurchase {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String       @db.ObjectId
  giftCardId   String       @db.ObjectId
  giftCategory GiftCategory
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  // Relations 
  user         User         @relation(fields: [userId], references: [id])
  giftCard     GiftCard     @relation(fields: [giftCardId], references: [id])
}

model UserLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Je user like dicche
  user   User   @relation("UserLikesGiven", fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  // Je user ke like kora hocche
  likedUser   User   @relation("UserLikesReceived", fields: [likedUserId], references: [id], onDelete: Cascade)
  likedUserId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, likedUserId]) // prevent duplicate likes
}

model GiftSend {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  senderId     String       @db.ObjectId
  receiverId   String       @db.ObjectId
  giftCategory GiftCategory
  giftCardId   String       @db.ObjectId
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  sender   User     @relation("GiftSender", fields: [senderId], references: [id])
  receiver User     @relation("GiftReceiver", fields: [receiverId], references: [id])
  giftCard GiftCard @relation(fields: [giftCardId], references: [id])
}

enum GiftCategory {
  ESSENTIAL
  EXCLUSIVE
  MAJESTIC
}

model Payment {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  senderId        String        @db.ObjectId
  amount          Float
  totalCoins      Float         @default(0)
  currency        String        @default("USD")
  method          PaymentMethod
  paymentMethodId String
  status          PaymentStatus @default(PENDING)
  transactionId   String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sender          User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

//subscription start

model SubscriptionPlan {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String         @unique
  price        Float
  currency     String         @default("USD")
  interval     String // 'MONTH', 'YEAR', etc.
  subtitle     String?        @default("")
  discount     String?        @default("")
  trialDays    Int?           @default(0) // optional trial days
  active       Boolean        @default(true)
  features     Json? // array of objects [{ key: string, value: string }]
  createdAt    DateTime       @default(now())
  Subscription Subscription[]

  @@map("subscriptionPlans")
}

model Subscription {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  userId        String             @db.ObjectId
  planId        String             @db.ObjectId
  amount        Float
  status        subscriptionStatus @default(ACTIVE) // 'ACTIVE', 'CANCELLED', 'PAUSED', 'EXPIRED'
  startedAt     DateTime           @default(now())
  endedAt       DateTime?
  nextBillingAt DateTime?
  trialEndsAt   DateTime?
  metadata      Json?
  createdAt     DateTime           @default(now())
  plan          SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
}

//subscription end

enum subscriptionStatus {
  ACTIVE
  CANCELLED
  PAUSED
  EXPIRED
}

model TotalVisitors {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @default("") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ModeType {
  DATING
  SOCIAL
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  REQUIRES_CAPTURE
}

