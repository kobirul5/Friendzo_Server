generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  profileImage String?
  firstName    String?
  lastName     String?
  email        String     @unique
  phoneNumber  String?
  password     String?
  interests    String[]   @default([])
  fcmToken     String?
  role         UserRole   @default(USER)
  status       UserStatus @default(INACTIVE)

  isVerified       Boolean   @default(false)
  otp              Int?
  expirationOtp    DateTime?
  gender           String?
  dob              DateTime?
  lat              Float?
  lng              Float?
  isNotificationOn Boolean   @default(true)

  provider   String? // google, facebook etc
  providerId String? // social provider id
  memories   Memory[]
  event      Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  EventLike     EventLike[]
  MemoryLike    MemoryLike[]
  Comment       Comment[]
  followers     Follow[]     @relation("Followers")
  following     Follow[]     @relation("Following")
  SentChats     Chat[]       @relation("SentChats")
  ReceivedChats Chat[]       @relation("ReceivedChats")

  SenderRooms   Room[] @relation("SenderRooms")
  ReceiverRooms Room[] @relation("ReceiverRooms")

  reportsMade    Report[] @relation("ReportCreatedBy")
  reportsOnMe    Report[] @relation("ReportedUser")
  blockedUsers   Block[]  @relation("BlockerRelation")
  blockedByUsers Block[]  @relation("BlockedRelation")

  @@map("users")
}

model Memory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  description String
  address     String?
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId     String       @db.ObjectId
  user       User         @relation(fields: [userId], references: [id])
  MemoryLike MemoryLike[]
  Comment    Comment[]
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  description String
  address     String?
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  EventLike EventLike[]
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model EventLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.ObjectId

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemoryLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.ObjectId

  memory   Memory @relation(fields: [memoryId], references: [id])
  memoryId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  content String

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.ObjectId

  memory   Memory @relation(fields: [memoryId], references: [id])
  memoryId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  follower   User   @relation("Following", fields: [followerId], references: [id])
  followerId String @db.ObjectId

  following   User   @relation("Followers", fields: [followingId], references: [id])
  followingId String @db.ObjectId

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
}

model Chat {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    String
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  roomId     String   @db.ObjectId
  images     String[] @default([])

  isRead Boolean @default(false)

  sender   User @relation("SentChats", fields: [senderId], references: [id])
  receiver User @relation("ReceivedChats", fields: [receiverId], references: [id])
  room     Room @relation(fields: [roomId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String @db.ObjectId
  receiverId String @db.ObjectId
  sender     User   @relation("SenderRooms", fields: [senderId], references: [id])
  receiver   User   @relation("ReceiverRooms", fields: [receiverId], references: [id])
  chats      Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Reporter 
  reporterId String @db.ObjectId
  reporter   User   @relation("ReportCreatedBy", fields: [reporterId], references: [id])

  // Reported user
  reportedUserId String @db.ObjectId
  reportedUser   User   @relation("ReportedUser", fields: [reportedUserId], references: [id])
}

model Block {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  blockerId     String   @db.ObjectId
  blockedUserId String   @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blocker     User @relation("BlockerRelation", fields: [blockerId], references: [id])
  blockedUser User @relation("BlockedRelation", fields: [blockedUserId], references: [id])

  @@unique([blockerId, blockedUserId]) // Prevent duplicate blocks
}

